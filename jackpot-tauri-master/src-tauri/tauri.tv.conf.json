{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Jackpot TV",
  "version": "1.0.0",
  "identifier": "com.seite.jackpot-tv",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420/tv.html",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Jackpot TV Screen",
        "fullscreen": true,
        "alwaysOnTop": true,
        "url": "tv.html#/tv"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
